<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <!-- We are going to show the product through this ejs file -->
    <h1>Products Page</h1>
    <div class="row">
      <!-- Products are sent to display -->
     <% products.forEach(product => { %>
        <div class="box">
          <img src="<%=product.imageUrl %>" width="300px" alt="<%= product.name %>">
            <h2><%= product.name %></h2>
            <p><%= product.desc %></p>
            <h4><%= product.price %></h4>
        </div>
     <% }) %>
    </div>
  </body>
</html>