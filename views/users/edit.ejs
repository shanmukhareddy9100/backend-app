<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
        <h2>Edit User Details Form</h2>
        <form action="/users/<%= user._id %>/save" method="post">
            <p><input type="text" name="name" value="<%=user.name %>" placeholder="User Name"></p>
            <p><input type="email" name="email" value="<%=user.email %>" placeholder="User Email"></p>
            <p><input type="password" name="password" value="<%=user.password %>" placeholder="User Password"></p>
            <p><input type="text" name="role" value="<%=user.role %>" placeholder="User Role"></p>
            <button >Submit</button>
        </form>
</body>
</html>